						envCache : null(Unit),
						content : null(Unit) ,
						properties : none >),
				subcomponents : (
					< x : Data |
						features : (
							none),
						subcomponents : (
							none),
						value : param(Real),
						properties : (
							none),
						connections : (
							empty) 
						> 
					< p : Data |
						features : (
