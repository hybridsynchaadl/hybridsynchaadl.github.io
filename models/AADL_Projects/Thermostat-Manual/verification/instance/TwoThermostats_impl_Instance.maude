mod TWOTHERMOSTATS_IMPL_INSTANCE-MODEL is
	including MODEL-TRANSITION-SYSTEM .
	
	--- AADL identifiers
	ops t : -> VarId [ctor] .
	ops temp offcontrol tin oncontrol power curr tout setpower : -> FeatureId [ctor] .
	ops TwoThermostatsimplInstance p thermProcess avg x env2 env1 ctrl2 ctrl1 thermThread : -> ComponentId [ctor] .
	ops init heaterOn heaterOff exec : -> Location [ctor] .
	ops loopBoundNum transBoundNum : -> Nat .
	--- the initial state
	op initial : -> Object .
	eq initial = < TwoThermostatsimplInstance : System |
		features : (
			none),
		subcomponents : (
			< ctrl1 : System |
				features : (
					< setpower : DataOutPort | 
						content : null(Real) ,
						properties : (DataModel::InitialValue => {{0}}) >
					< curr : DataInPort | 
						cache : null(Real),
						content : null(Real) ,
						properties : none >
					< tin : DataInPort | 
						cache : null(Real),
						content : null(Real) ,
						properties : none >
					< tout : DataOutPort | 
						content : null(Real) ,
						properties : (DataModel::InitialValue => {{0}}) >
					< oncontrol : DataOutPort | 
						content : null(Unit) ,
						properties : none >
					< offcontrol : DataOutPort | 
						content : null(Unit) ,
						properties : none >),
				subcomponents : (
					< thermProcess : Process |
						features : (
							< setpower : DataOutPort | 
								content : null(Real) ,
								properties : none >
							< curr : DataInPort | 
								cache : null(Real),
								content : null(Real) ,
								properties : none >
							< tin : DataInPort | 
								cache : null(Real),
