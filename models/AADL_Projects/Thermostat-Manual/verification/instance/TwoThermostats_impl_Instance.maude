							< tout : DataOutPort | 
								content : null(Real) ,
								properties : none >
							< oncontrol : DataOutPort | 
								content : null(Unit) ,
								properties : none >
							< offcontrol : DataOutPort | 
								content : null(Unit) ,
								properties : none >),
						subcomponents : (
							< thermThread : Thread |
								features : (
									< setpower : DataOutPort | 
										content : null(Real) ,
										properties : none >
									< curr : DataInPort | 
										cache : null(Real),
										content : null(Real) ,
										properties : none >
									< tin : DataInPort | 
										cache : null(Real),
										content : null(Real) ,
										properties : none >
									< tout : DataOutPort | 
										content : null(Real) ,
										properties : none >
									< oncontrol : DataOutPort | 
										content : null(Unit) ,
										properties : none >
									< offcontrol : DataOutPort | 
										content : null(Unit) ,
										properties : none >),
								subcomponents : (
									< avg : Data |
										features : (
											none),
										subcomponents : (
											none),
										value : param(Real),
										properties : (
											none),
										connections : (
											empty) 
										> ),
								currState : (
									init),
								completeStates : (
									init),
								variables : (
									empty),
								transitions : (
									(init -[ on dispatch ]-> exec {
										(c{avg} := ((f[tin] + f[curr]) / [[2]])) ;
										(f{tout} := f[curr])
									}) ;
									(exec -[ (c[avg] > [[25]]) ]-> init {
										(offcontrol !)
									}) ;
									(exec -[ ((c[avg] < [[20]]) and (c[avg] >= [[10]])) ]-> init {
										(f{setpower} := [[5]]) ;
										(oncontrol !)
									}) ;
									(exec -[ (c[avg] < [[10]]) ]-> init {
										(f{setpower} := [[10]]) ;
										(oncontrol !)
									})),
								loopBound : (
									loopBoundNum),
								transBound : (
									transBoundNum),
								varGen : (
									< "TwoThermostatsimplInstance.ctrl1.thermProcess.thermThread" >
									),
								properties : (
									(TimingProperties::Period => {{10.0}}) ;
									(HybridSynchAADL::MaxClockDeviation => {{1.0}}) ;
									(HybridSynchAADL::Synchronous => {{true}}) ;
									(HybridSynchAADL::SamplingTime => {{1.0 .. 5.0}}) ;
									(HybridSynchAADL::ResponseTime => {{7.0 .. 9.0}})),
								connections : (
									empty) 
								> ),
						properties : (
							(TimingProperties::Period => {{10.0}}) ;
							(HybridSynchAADL::Synchronous => {{true}})),
						connections : (
							(thermThread .. tout --> tout) ;
							(curr --> thermThread .. curr) ;
							(thermThread .. setpower --> setpower) ;
							(thermThread .. oncontrol --> oncontrol) ;
							(thermThread .. offcontrol --> offcontrol) ;
							(tin --> thermThread .. tin)) 
						> ),
				properties : (
					(TimingProperties::Period => {{10.0}}) ;
					(HybridSynchAADL::MaxClockDeviation => {{1.0}}) ;
					(HybridSynchAADL::Synchronous => {{true}})),
				connections : (
					(thermProcess .. offcontrol --> offcontrol) ;
					(tin --> thermProcess .. tin) ;
					(thermProcess .. tout --> tout) ;
					(curr --> thermProcess .. curr) ;
					(thermProcess .. oncontrol --> oncontrol) ;
					(thermProcess .. setpower --> setpower)) 
				> 
			< ctrl2 : System |
				features : (
					< setpower : DataOutPort | 
						content : null(Real) ,
						properties : (DataModel::InitialValue => {{0}}) >
					< curr : DataInPort | 
						cache : null(Real),
						content : null(Real) ,
						properties : none >
					< tin : DataInPort | 
